# Sentry DSN (opcional). Si está vacío, Sentry NO se inicializa.
VITE_SENTRY_DSN=

# Firebase (web app config). Si VITE_FIREBASE_API_KEY está vacío, Firebase NO se inicializa.
# Las API keys de Firebase son públicas por diseño — la seguridad la da Security Rules + App Check.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
